# ─── Supabase (trip sync between web & mobile) ───────────────────────────────
# 1. Go to https://supabase.com and create a free project
# 2. Go to Settings → API and copy the URL + anon key
# 3. Run the SQL below in the SQL Editor to create the trips table
# Without these, the app falls back to localStorage (no sync)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ─── Image Search (Google Custom Search) ─────────────────────────────────────
# 1. Go to https://developers.google.com/custom-search/v1/introduction
#    and create a free API key (100 searches/day free)
# 2. Go to https://cse.google.com/cse/all and create a Custom Search Engine
#    - Set "Search the entire web" → ON
#    - Enable "Image search" in Settings → Search features → Image search
# 3. Copy the key and CX (Search engine ID) here, then rename this file to .env.local

VITE_GOOGLE_API_KEY=your_google_api_key_here
VITE_GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ─── Alternative: Unsplash (fallback if Google not configured) ────────────────
# Register at https://unsplash.com/developers (free, 50 req/hr)
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ─── Pexels (secondary fallback — 200 req/hr free) ────────────────────────────
# Register at https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here
