# ─── Mapbox (public token — restrict via Mapbox dashboard domain allowlist) ───
VITE_MAPBOX_TOKEN=your_mapbox_public_token

# ─── Server-only keys (NO VITE_ prefix — proxied via /api/ routes) ────────────

# Mapbox (used for geocoding proxy — can be same as VITE_MAPBOX_TOKEN)
MAPBOX_TOKEN=your_mapbox_token

# Image Search (Google Custom Search)
# 1. Go to https://developers.google.com/custom-search/v1/introduction
# 2. Create a Custom Search Engine at https://cse.google.com/cse/all
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Unsplash (fallback if Google not configured — 50 req/hr free)
# Register at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels (secondary fallback — 200 req/hr free)
# Register at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# AeroDataBox via RapidAPI (flight schedules & routes)
# Get your key at https://rapidapi.com/aedbx-aedbx/api/aerodatabox
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Firebase (public config — auth enforced by Firestore security rules) ─────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
