rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the caller is an admin/owner of a given org ────────
    function isOrgAdmin(orgId) {
      let mem = get(/databases/$(database)/documents/org_members/$(request.auth.uid + '_' + orgId));
      return mem != null && mem.data.role in ["owner", "admin"];
    }

    function isOrgMember(orgId) {
      return exists(/databases/$(database)/documents/org_members/$(request.auth.uid + '_' + orgId));
    }

    // ── System cron user (flight status checker) ──────────────────────────
    function isCronUser() {
      return request.auth != null
             && request.auth.token.email == "cron@dalefy.com";
    }

    // ── Helper: check if the caller is a trip member (by auth UID) ──────
    function isTripMember(tripId) {
      return exists(/databases/$(database)/documents/trip_members/$(request.auth.uid + '_' + tripId));
    }

    // ── Profiles: users can read/write only their own ──────────────────────
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      // Any authenticated user can read (needed for agency code uniqueness checks)
      allow read: if request.auth != null;
      // Any authenticated user can create (they become owner via org_members)
      allow create: if request.auth != null;
      // Only admins/owners can update or delete
      allow update, delete: if request.auth != null && isOrgAdmin(orgId);
    }

    // ── Org members ────────────────────────────────────────────────────────
    match /org_members/{docId} {
      // Authenticated users can read memberships (needed for org bootstrapping and member lists)
      allow read: if request.auth != null;

      // Only the org creator can create the first membership (owner bootstrap);
      // after that, only admins/owners of the org can add members
      allow create: if request.auth != null
        && request.resource.data.user_id is string
        && request.resource.data.organization_id is string
        && (
          // Bootstrap: the user is creating their own owner membership
          (request.resource.data.user_id == request.auth.uid
           && request.resource.data.role == "owner")
          ||
          // Existing admin/owner is adding a member
          isOrgAdmin(request.resource.data.organization_id)
        );

      // Only org admins/owners can update roles; users can remove themselves
      allow update: if request.auth != null
        && isOrgAdmin(resource.data.organization_id);

      allow delete: if request.auth != null
        && (resource.data.user_id == request.auth.uid
            || isOrgAdmin(resource.data.organization_id));
    }

    // ── Org branding ───────────────────────────────────────────────────────
    match /org_branding/{orgId} {
      // Anyone can read (needed for shared/public trip pages)
      allow read: if true;
      // Only org admins/owners can write
      allow write: if request.auth != null && isOrgAdmin(orgId);
    }

    // ── Trips ──────────────────────────────────────────────────────────────
    match /trips/{tripId} {
      // Published trips are readable by anyone (shared links, PIN join flow).
      // Non-published trips require ownership, membership, org membership, or cron.
      allow read: if resource.data.status in ["Published", "published"]
                  || (request.auth != null
                      && (resource.data.user_id == request.auth.uid
                          || isCronUser()
                          || isTripMember(tripId)
                          || (resource.data.organization_id != null
                              && isOrgMember(resource.data.organization_id))));

      // Only authenticated users can create; user_id must match caller
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;

      // The creator, org admin, cron user, or trip member can update;
      // only creator/org admin/cron can delete
      allow update: if request.auth != null
                    && (resource.data.user_id == request.auth.uid
                        || isCronUser()
                        || isTripMember(tripId)
                        || (resource.data.organization_id != null
                            && isOrgAdmin(resource.data.organization_id)));
      allow delete: if request.auth != null
                    && (resource.data.user_id == request.auth.uid
                        || isCronUser()
                        || (resource.data.organization_id != null
                            && isOrgAdmin(resource.data.organization_id)));
    }

    // ── Trip members ───────────────────────────────────────────────────────
    match /trip_members/{docId} {
      // Read: authenticated users only
      allow read: if request.auth != null;

      // Create: must be authenticated, include a trip_id, and either
      // device_id or a matching uid/user_id
      allow create: if request.auth != null
                    && request.resource.data.trip_id is string
                    && request.resource.data.trip_id.size() > 0
                    && (request.resource.data.device_id is string
                        || request.resource.data.uid == request.auth.uid
                        || request.resource.data.user_id == request.auth.uid);

      // The member themselves, the trip owner, or an org admin can update/delete.
      allow update, delete: if request.auth != null
        && (resource.data.user_id == request.auth.uid
            || resource.data.uid == request.auth.uid
            || resource.data.device_id == request.auth.uid
            || exists(/databases/$(database)/documents/trip_members/$(request.auth.uid + '_' + resource.data.trip_id))
            || get(/databases/$(database)/documents/trips/$(resource.data.trip_id)).data.user_id == request.auth.uid
            || (get(/databases/$(database)/documents/trips/$(resource.data.trip_id)).data.organization_id != null
                && isOrgAdmin(get(/databases/$(database)/documents/trips/$(resource.data.trip_id)).data.organization_id)));
    }

    // ── Push tokens: scoped to owning user (cron can read all for notifications)
    match /push_tokens/{docId} {
      allow read: if request.auth != null
                  && (resource.data.user_id == request.auth.uid || isCronUser());
      allow create, update: if request.auth != null
                            && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
