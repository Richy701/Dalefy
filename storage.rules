rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Avatar uploads: scoped by auth UID, max 2MB, images only
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // Logo uploads: namespaced by org ID, then by uploading user's UID.
    // Storage rules cannot cross-reference Firestore, so org-admin checks
    // are enforced in the application layer. The UID scope prevents users
    // from overwriting each other's uploads.
    match /logos/{orgId}/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }
    // Legacy flat path (read-only for existing logos)
    match /logos/{orgId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Trip media: scoped by trip ID + uploader UID.
    // Users can only write/delete under their own UID subfolder.
    match /trips/{tripId}/media/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*');
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }
    // Legacy flat path (read-only for existing media uploaded before UID scoping)
    match /trips/{tripId}/media/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Event-level media (itinerary attachments, uploaded by organiser)
    match /trips/{tripId}/events/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('(image|video)/.*');
    }

    // Trip-level documents (PDFs, vouchers, etc.)
    match /trips/{tripId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
