{
  "expo": {
    "name": "Dalefy",
    "slug": "daf-adventures",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-quick-actions"
    ],
    "scheme": "dafadventures",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#131316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dafadventures.app",
      "infoPlist": {
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Dalefy uses your location to show nearby trip activities and provide directions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#131316"
      },
      "package": "com.dafadventures.app",
      "backgroundColor": "#131316",
      "navigationBarColor": "#09090b",
      "navigationBarStyle": "light-content",
      "statusBarColor": "#00000000",
      "statusBarStyle": "light-content",
      "statusBarTranslucent": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.dafadventures.app.widgets",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.dafadventures.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "4bffc7b2-6f5d-481c-8712-44e8d9107dbb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4bffc7b2-6f5d-481c-8712-44e8d9107dbb"
    },
    "owner": "richmond701"
  }
}
